{
  "name": "@niche-ui/tree",
  "version": "0.1.0",
  "description": "Binary tree and AST visualiser — headless, styled, or hook-only",
  "license": "MIT",
  "main":   "./dist/index.cjs",
  "module": "./dist/index.js",
  "types":  "./dist/index.d.ts",
  "exports": {
    ".": {
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs",
      "types":   "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "sideEffects": false,
  "scripts": {
    "build":     "vite build",
    "dev":       "vite build --watch",
    "typecheck": "tsc --noEmit",
    "test":      "vitest run",
    "test:watch":"vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "dependencies": {
    "@niche-ui/utils": "workspace:*"
  },
  "devDependencies": {
    "@niche-ui/tsconfig":   "workspace:*",
    "@types/react":         "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite":                 "^5.4.0",
    "vite-plugin-dts":      "^3.9.0",
    "typescript":           "^5.4.0",
    "vitest":               "^1.6.0",
    "@vitest/coverage-v8":  "^1.6.0",
    "jsdom":                "^24.0.0"
  }
}
